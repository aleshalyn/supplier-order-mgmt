class Product:
    def __init__(self, product_id, name, price):
        if price <= 0:
            raise ValueError("Price must be greater than zero")

        self.product_id = product_id
        self.name = name
        self.price = price
        self.suppliers = []

    def add_supplier(self, supplier):
        if supplier not in self.suppliers:
            self.suppliers.append(supplier)


class Supplier:
    def __init__(self, supplier_id, name):
        self.supplier_id = supplier_id
        self.name = name
        self.products = []

    def add_product(self, product):
        if product not in self.products:
            self.products.append(product)
            product.add_supplier(self)


class System:
    def __init__(self):
        self.products = []
        self.suppliers = []

    # ---------------- ADD PRODUCT ----------------
    def add_product(self):
        pid = input("Enter Product ID: ")
        name = input("Enter Product Name: ")

        try:
            price = float(input("Enter Price: "))
            if price <= 0:
                print("❌ Price must be greater than zero")
                return
        except:
            print("❌ Invalid price input")
            return

        product = Product(pid, name, price)
        self.products.append(product)
        print("✅ Product added successfully")

    # ---------------- ADD SUPPLIER ----------------
    def add_supplier(self):
        sid = input("Enter Supplier ID: ")
        name = input("Enter Supplier Name: ")

        supplier = Supplier(sid, name)
        self.suppliers.append(supplier)
        print("✅ Supplier added successfully")

    # ---------------- FINDERS ----------------
    def find_product(self, pid):
        for p in self.products:
            if p.product_id == pid:
                return p
        return None

    def find_supplier(self, sid):
        for s in self.suppliers:
            if s.supplier_id == sid:
                return s
        return None

    # ---------------- LINKING ----------------
    def link_product_supplier(self):
        pid = input("Enter Product ID: ")
        sid = input("Enter Supplier ID: ")

        product = self.find_product(pid)
        supplier = self.find_supplier(sid)

        # RULE: product must exist
        if product is None:
            print("❌ Product does not exist")
            return

        # RULE: supplier must exist
        if supplier is None:
            print("❌ Supplier does not exist")
            return

        supplier.add_product(product)
        print("✅ Product successfully linked to supplier")

    # ---------------- VIEW CATALOG ----------------
    def view_supplier_catalog(self):
        sid = input("Enter Supplier ID: ")

        supplier = self.find_supplier(sid)

        if supplier is None:
            print("❌ Supplier not found")
            return

        print(f"\n📦 {supplier.name} Product Catalog:")

        if not supplier.products:
            print("No products assigned")
            return

        for p in supplier.products:
            print(f"- {p.name} (₱{p.price})")

    # ---------------- MENU ----------------
    def menu(self):
        while True:
            print("\n===== PRODUCT & SUPPLIER SYSTEM =====")
            print("1. Add Product")
            print("2. Add Supplier")
            print("3. Link Product to Supplier")
            print("4. View Supplier Catalog")
            print("5. Exit")

            choice = input("Enter choice: ")

            if choice == "1":
                self.add_product()
            elif choice == "2":
                self.add_supplier()
            elif choice == "3":
                self.link_product_supplier()
            elif choice == "4":
                self.view_supplier_catalog()
            elif choice == "5":
                print("Exiting system...")
                break
            else:
                print("❌ Invalid choice")


# RUN SYSTEM
if __name__ == "__main__":
    system = System()
    system.menu()
